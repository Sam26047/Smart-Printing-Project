# PrintFlow Print Agent — copy this to .env and fill in your values

# URL of your PrintFlow backend (VPS or local network)
BACKEND_URL=http://your-vps-ip:5000

# Per-shop device token issued by the backend (shown once at issuance):
#   POST /shops/:shopId/agent-tokens  (as that shop's admin)
# Looks like: pfa_<uuid>.<secret>
AGENT_TOKEN=pfa_xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx.your-secret-here

# Exact Windows printer name (find it in Control Panel → Devices and Printers)
# Right-click the printer → see the name at the top of the properties dialog
PRINTER_NAME=EPSON L3000 Series

# How often to poll for new jobs (milliseconds). 5000 = every 5 seconds.
POLL_MS=5000
