# PrintFlow root .env — copy to .env and fill in real values.
# Every value here is a PLACEHOLDER. Never commit the real .env.

# ── Postgres (backend connection + container bootstrap — passwords must match) ─
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=change-me-random-hex          # node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
DB_NAME=printing_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-same-as-DB_PASSWORD
POSTGRES_DB=printing_db

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Auth ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-random-hex-64        # node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

# ── Email (nodemailer / SMTP) ─────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=you@example.com
EMAIL_PASS=your-gmail-app-password        # Google account → App Passwords
EMAIL_FROM=you@example.com

# ── Razorpay (TEST keys — dashboard → API Keys) ───────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-test-key-secret
# Webhook signing secret (HMAC-SHA256). Must match the secret set in the
# Razorpay dashboard webhook config (any agreed value for local testing).
RAZORPAY_WEBHOOK_SECRET=change-me-random-hex

# ── Demo virtual-printer worker (optional) ────────────────────────────────────
# Agent token for the 'demo' VIRTUAL shop — mint as demo_admin via
# POST /shops/<demoShopId>/agent-tokens. If set, the backend starts the
# virtual worker that "prints" demo jobs by stamping the PDFs.
DEMO_AGENT_TOKEN=pfa_xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx.your-demo-token-secret
DEMO_PRINT_DELAY_MS=6000

# Agent auth is per-shop device tokens in the agent_tokens table — no env var.
# (Legacy PRINTER_URI / PRINTER_MOCK are unused by current code.)
